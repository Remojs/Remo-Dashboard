# ─── Interaktive Admin Dashboard — Variables de Entorno ───────────────────────
# Copiá este archivo a .env y completá los valores antes de correr docker compose
#
#   cp .env.example .env

# ── Backend ────────────────────────────────────────────────────────────────────
# Un string largo y random — generá con: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

JWT_EXPIRES_IN=7d

# Exactamente 32 caracteres para AES-256
ENCRYPTION_KEY=replace_with_32_char_key_here!!!

# ── Frontend ───────────────────────────────────────────────────────────────────
# URL que el browser del usuario usa para llegar al API.
# En Easypanel con dominio: https://api.tudominio.com/api
# Con IP directa: http://TU_IP_VPS:4000/api
NEXT_PUBLIC_API_URL=http://TU_IP_VPS:4000/api

# CORS — debe coincidir con la URL del frontend
CORS_ORIGIN=http://TU_IP_VPS:3000

# ── Puertos opcionales ─────────────────────────────────────────────────────────
# BACKEND_PORT=4000
# FRONTEND_PORT=3000
